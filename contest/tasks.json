{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build cpp",
            "type": "shell",
            "command": "clang++",
            "args": [
                "-g",
                "main.cpp",
                "-o",
                "main.exe"
            ]
        },
        {
            "label": "run cpp",
            "type": "shell",
            "command": "${workspaceFolder}/main.exe",
            "dependsOn": "build cpp"
        }
    ]
}